{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=oasis.db"
  },
  "Jwt": {
    "Issuer": "JiraIntegration.Server",
    "Audience": "JiraIntegration.Client",
    "Secret": "",
    "ExpiryMinutes": 60
  },
  "Atlassian": {
    "RedirectUri": "http://localhost:5282/api/jira/callback",
    "Scopes": "read:jira-user read:jira-work write:jira-work offline_access",
    "FrontendSuccessUrl": "http://localhost:4200/jira-connected"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  }
}
